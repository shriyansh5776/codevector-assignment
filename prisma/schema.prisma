generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Category {
  ELECTRONICS
  BOOKS
  FASHION
  SPORTS
  HOME
  BEAUTY
  TOYS
}

model Product {
  id         String   @id @default(cuid())
  name       String
  category   Category
  sellingPrice Float

  description String?   // New field

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt, id])
  @@index([createdAt])
}